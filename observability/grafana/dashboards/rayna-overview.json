{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Rayna — API / DB / Redis / BullMQ Overview",
  "uid": "rayna-overview",
  "tags": ["rayna", "phase1"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate (req/s by route)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (route) (rate(rayna_http_request_duration_seconds_count[5m]))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 latency (by route)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, route) (rate(rayna_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 3,
      "title": "Event-loop lag p99 (worker/API health)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rayna_nodejs_eventloop_lag_p99_seconds", "legendFormat": "event-loop lag p99" }
      ]
    },
    {
      "id": 4,
      "title": "Process memory (RSS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rayna_process_resident_memory_bytes", "legendFormat": "rss" }
      ]
    },
    {
      "id": 5,
      "title": "BullMQ queue depth (waiting/active/delayed)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rayna_bullmq_queue_depth{state=~\"waiting|active|delayed\"}", "legendFormat": "{{queue}} / {{state}}" }
      ]
    },
    {
      "id": 6,
      "title": "BullMQ job throughput (jobs/s by status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (queue, status) (rate(rayna_bullmq_jobs_total[5m]))", "legendFormat": "{{queue}} / {{status}}" }
      ]
    },
    {
      "id": 7,
      "title": "BullMQ job duration p95 (by queue)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, queue) (rate(rayna_bullmq_job_duration_seconds_bucket[5m])))", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "id": 8,
      "title": "Postgres — active connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (state) (pg_stat_activity_count)", "legendFormat": "{{state}}" }
      ]
    }
  ]
}
